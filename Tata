/* ════════ LOADING ════════ */
var bootLines = [
  '> WAVARA DEFENSE NETWORK — BOOT SEQUENCE INITIATED',
  '> [  OK  ] Seismic sensor array — 47 stations online',
  '> [  OK  ] DART buoy network — 12 units active',
  '> [  OK  ] Satellite uplink — signal locked',
