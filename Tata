function startWaveAnim() {
  if(waveRAF)return;
  var t=0;
  function frame() {
    t+=0.038;
    var f=parseFloat(document.getElementById('ws-f').value)||1;
    var a=parseFloat(document.getElementById('ws-a').value)||30;
    var W=560,H=100;
    var pts=[];
    for(var x=0;x<=W;x+=2){ var y=H/2+a*Math.sin((x/W)*f*Math.PI*4-t*f); pts.push(x+','+y); }
    var wp=document.getElementById('ws-path'); if(wp)wp.setAttribute('d','M '+pts.join(' L '));
    var lPx=W/(f*2);
    var wlLine=document.getElementById('ws-wl-line'); if(wlLine)wlLine.setAttribute('x2',lPx);
    var wlTxt=document.getElementById('ws-wl-txt'); if(wlTxt)wlTxt.setAttribute('x',lPx/2);
    var crest=document.getElementById('ws-crest'); if(crest){crest.setAttribute('cx',W/(f*4));crest.setAttribute('cy',H/2-a);}
    var tvPts=[];
    for(var i=0;i<16;i++){var xi=20+i*32;var yi=48+26*Math.sin(i*0.7-t*2);tvPts.push(xi+','+yi);}
    var tvp=document.getElementById('tv-path'); if(tvp)tvp.setAttribute('d','M '+tvPts.join(' L '));
    var lg=document.getElementById('lv-dots');
    if(lg){var s='';for(var i2=0;i2<20;i2++){var bx=14+i2*24;var dx=10*Math.sin(i2*0.8-t*2);s+='<circle cx="'+(bx+dx)+'" cy="48" r="4" fill="rgba(245,158,11,.65)" opacity=".8"/>';}lg.innerHTML=s;}
    waveRAF=requestAnimationFrame(frame);
  }
  frame();
}
function stopWaveAnim(){if(waveRAF){cancelAnimationFrame(waveRAF);waveRAF=null;}}

