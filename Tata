}

function updateLiveData() {
  var sm = seisTime(), ta = tsuTime(), adv = hybridAdv(), rel = reliab(), thr = threatPct();
  setText('dr-seis', sm.toFixed(1));
  setText('dr-buoy', (sm * 3).toFixed(0));
