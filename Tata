<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Operation WaveGuard — WAVARA Defense Network</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,300&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#081018;--panel:#111827;--panel2:#1b2a3a;--border:rgba(255,255,255,.05);--border2:#2e4460;
  --accent:#315c67;--blue:#3b82f6;--seafoam:#7dd3c7;--seafoam2:#5bc0be;
  --red:#dc2626;--red2:#ef4444;--amber:#f59e0b;--green:#10b981;
  --text:#e5eef5;--muted:#9fb3c8;--muted2:#7a96ae;--deep:#040c14;
  --ease-out-expo:cubic-bezier(.22,1,.36,1);
  --ease-in-out-cubic:cubic-bezier(.65,0,.35,1);
}
html,body{width:100%;overflow-x:hidden;min-height:100vh}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Inter',system-ui,sans-serif;
  font-size:14px;
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:rgba(125,211,199,.15);border-radius:2px}
button{font-family:'Inter',inherit;cursor:pointer;border:none;outline:none}
input[type=range]{-webkit-appearance:none;width:100%;height:2px;background:rgba(36,52,71,.9);border-radius:2px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--seafoam);cursor:pointer;border:2px solid var(--bg);transition:transform .2s var(--ease-out-expo),box-shadow .2s}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.2);box-shadow:0 0 12px rgba(125,211,199,.35)}
input[type=password],input[type=text]{
  background:rgba(4,12,22,.9);
  border:1px solid rgba(255,255,255,.06);
  color:var(--text);
  padding:16px 20px;
  border-radius:8px;
  font-size:15px;
  outline:none;
  width:100%;
  transition:border .4s var(--ease-out-expo),box-shadow .4s var(--ease-out-expo);
  letter-spacing:3px;
  font-family:'Inter',sans-serif;
}
input[type=password]:focus,input[type=text]:focus{
  border-color:rgba(125,211,199,.3);
  box-shadow:0 0 0 3px rgba(125,211,199,.05),0 1px 40px rgba(125,211,199,.04);
}
input::placeholder{opacity:.3;letter-spacing:4px}

/* ── KEYFRAMES ── */
@keyframes waveScroll{from{background-position-x:0}to{background-position-x:300px}}
@keyframes waveDrift{0%{transform:translateX(0) scaleY(1)}50%{transform:translateX(-18px) scaleY(1.06)}100%{transform:translateX(0) scaleY(1)}}
@keyframes pulseRing{0%{transform:scale(.5);opacity:.9}100%{transform:scale(3);opacity:0}}
@keyframes radarSweep{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes blinkAlert{0%,100%{opacity:1}50%{opacity:.08}}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-9px)}75%{transform:translateX(9px)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scanline{0%{top:-4%}100%{top:104%}}
@keyframes starTwinkle{0%,100%{opacity:.08}50%{opacity:.6}}
@keyframes lockReveal{from{opacity:1;transform:scale(1)}to{opacity:0;transform:scale(1.04)}}
@keyframes dashIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes buoyBob{0%,100%{transform:translateY(0) rotate(-.8deg)}50%{transform:translateY(-7px) rotate(.8deg)}}
@keyframes bootText{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
@keyframes redFlash{0%,100%{background:rgba(220,38,38,.03)}50%{background:rgba(220,38,38,.1)}}
@keyframes terminalBlink{0%,49%{opacity:1}50%,100%{opacity:0}}
@keyframes lockdownGlow{0%,100%{box-shadow:inset 0 0 60px rgba(220,38,38,.04)}50%{box-shadow:inset 0 0 120px rgba(220,38,38,.12)}}
@keyframes orb{0%{transform:translate(0,0) scale(1)}33%{transform:translate(60px,-40px) scale(1.1)}66%{transform:translate(-40px,30px) scale(.9)}100%{transform:translate(0,0) scale(1)}}
@keyframes orbSlow{0%{transform:translate(0,0) scale(1)}50%{transform:translate(-80px,50px) scale(1.15)}100%{transform:translate(0,0) scale(1)}}
@keyframes rippleIn{0%{transform:scale(0);opacity:.8}100%{transform:scale(2.5);opacity:0}}
@keyframes heroFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes gradShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes slideInLeft{from{opacity:0;transform:translateX(-24px)}to{opacity:1;transform:translateX(0)}}

/* ── UTILITY ── */
.panel{
  background:rgba(17,24,39,.75);
  border:1px solid var(--border);
  border-radius:12px;
  padding:20px;
  position:relative;
  overflow:hidden;
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
}
.panel::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;
  height:1px;
  background:linear-gradient(90deg,transparent,rgba(125,211,199,.1),transparent);
}
.glass{
  background:rgba(8,18,30,.7);
  backdrop-filter:blur(28px);
  -webkit-backdrop-filter:blur(28px);
  border:1px solid rgba(255,255,255,.06);
  border-radius:16px;
}
.glass-light{
  background:rgba(27,42,58,.35);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.06);
  border-radius:10px;
}
.sec-title{
  font-size:8px;
  font-weight:600;
  letter-spacing:3.5px;
  text-transform:uppercase;
  color:var(--seafoam);
  margin-bottom:18px;
  display:flex;
  align-items:center;
  gap:10px;
  opacity:.85;
}
.sec-title::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,rgba(125,211,199,.15),transparent)}
.btn-p{
  background:transparent;
  border:1px solid rgba(125,211,199,.28);
  color:var(--seafoam);
  padding:12px 30px;
  border-radius:7px;
  font-weight:500;
  letter-spacing:1.5px;
  text-transform:uppercase;
  font-size:10.5px;
  transition:all .5s var(--ease-out-expo);
  font-family:'Inter',sans-serif;
}
.btn-p:hover{
  background:rgba(125,211,199,.07);
  border-color:rgba(125,211,199,.45);
  box-shadow:0 4px 30px rgba(125,211,199,.1);
  transform:translateY(-2px);
}
.btn-p:disabled{opacity:.25;cursor:not-allowed;transform:none}
.btn-d{
  background:transparent;
  border:1px solid rgba(239,68,68,.3);
  color:var(--red2);
  padding:11px 24px;
  border-radius:7px;
  font-weight:500;
  letter-spacing:1.5px;
  font-size:10.5px;
  transition:all .4s var(--ease-out-expo);
  font-family:'Inter',sans-serif;
}
.btn-d:hover{background:rgba(220,38,38,.07);border-color:rgba(239,68,68,.5);box-shadow:0 4px 24px rgba(220,38,38,.12)}
.btn-d:disabled{opacity:.25;cursor:not-allowed}
.tab-btn{
  background:transparent;
  border:1px solid rgba(255,255,255,.06);
  color:var(--muted2);
  padding:7px 14px;
  border-radius:6px;
  font-size:9px;
  letter-spacing:1px;
  text-transform:uppercase;
  font-weight:500;
  transition:all .3s var(--ease-out-expo);
  font-family:'Inter',sans-serif;
}
.tab-btn:hover{border-color:rgba(125,211,199,.2);color:var(--seafoam)}
.tab-btn.active{background:rgba(125,211,199,.07);border-color:rgba(125,211,199,.25);color:var(--seafoam)}
.badge{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:4px;font-size:7.5px;font-weight:600;letter-spacing:2px;text-transform:uppercase;font-family:'Inter',sans-serif}
.lvl-1{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);color:var(--green)}
.lvl-3{background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.2);color:var(--blue)}
.lvl-5{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);color:var(--amber)}
.lvl-sci{background:rgba(125,211,199,.06);border:1px solid rgba(125,211,199,.2);color:var(--seafoam)}
.bar{height:4px;border-radius:3px;background:rgba(36,52,71,.6);overflow:hidden}
.bar-fill{height:100%;border-radius:3px;transition:width .7s var(--ease-out-expo),background .5s}
.prog-bar{height:2px;background:rgba(36,52,71,.8);border-radius:2px;overflow:hidden}
.prog-fill{height:100%;border-radius:2px;transition:width .1s linear}
.gg{background-image:linear-gradient(rgba(36,52,71,.35) 1px,transparent 1px),linear-gradient(90deg,rgba(36,52,71,.35) 1px,transparent 1px);background-size:38px 38px}
.mono{font-family:'Courier New',Courier,monospace}
.serif{font-family:'Instrument Serif',Georgia,serif}
.page{display:none}.page.active{display:block;animation:fadeIn .5s var(--ease-out-expo)}
.omk-content{display:none}.omk-content.active{display:block}

/* ── NAVBAR ── */
#navbar{
  position:sticky;
  top:0;
  z-index:200;
  background:rgba(8,16,24,.88);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid rgba(255,255,255,.05);
  display:flex;
  align-items:center;
  gap:1px;
  padding:6px 24px;
  overflow-x:auto;
}
.nav-link{
  background:none;
  border:none;
  color:rgba(155,179,200,.55);
  padding:8px 13px;
  border-radius:6px;
  font-size:9px;
  font-weight:500;
  letter-spacing:1.5px;
  text-transform:uppercase;
  transition:all .3s var(--ease-out-expo);
  white-space:nowrap;
  font-family:'Inter',sans-serif;
}
.nav-link:hover{color:var(--seafoam);background:rgba(125,211,199,.05)}
.nav-link.active{color:var(--seafoam);background:rgba(125,211,199,.08)}

/* ── GRIDS ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
@media(max-width:900px){.g3{grid-template-columns:1fr 1fr}.g4{grid-template-columns:1fr 1fr}#sim-grid{grid-template-columns:1fr!important}}
@media(max-width:600px){.g2,.g3,.g4{grid-template-columns:1fr}}

.wrap{max-width:1260px;margin:0 auto;padding:40px 24px}
.sec-head{display:flex;align-items:center;gap:14px;margin-bottom:32px}
.sec-head h2{
  font-family:'Instrument Serif',Georgia,serif;
  color:var(--text);
  font-size:22px;
  font-weight:400;
  font-style:italic;
  letter-spacing:.5px;
}
.sec-head::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,rgba(125,211,199,.12),transparent)}
.sci-card{
  background:linear-gradient(145deg,rgba(27,42,58,.6),rgba(17,24,39,.7));
  border:1px solid rgba(255,255,255,.05);
  border-radius:13px;
  padding:24px;
  position:relative;
  overflow:hidden;
  transition:all .6s var(--ease-out-expo);
  backdrop-filter:blur(10px);
}
.sci-card:hover{
  border-color:rgba(125,211,199,.15);
  box-shadow:0 20px 60px rgba(0,0,0,.35),0 0 40px rgba(125,211,199,.04);
  transform:translateY(-3px);
}
.s-status{transition:color .4s}

/* ── FIXED SCREENS ── */
#lock-screen{position:fixed;inset:0;z-index:9999;overflow:hidden;background:var(--deep)}
#loading-screen{position:fixed;inset:0;z-index:9998;background:var(--bg);display:none;flex-direction:column;align-items:center;justify-content:center}
#lockdown-screen{position:fixed;inset:0;z-index:10000;display:none;flex-direction:column;align-items:center;justify-content:center;background:#04080f;animation:lockdownGlow 3s ease-in-out infinite}
#denial-screen{position:fixed;inset:0;z-index:10001;display:none;flex-direction:column;align-items:center;justify-content:center;background:#000}
#omk-lock-screen{position:fixed;inset:0;z-index:9999;display:none;align-items:center;justify-content:center;background:rgba(4,8,16,.98)}
#omk-overlay{position:fixed;inset:0;z-index:8000;background:rgba(4,10,20,.97);display:none;overflow-y:auto;backdrop-filter:blur(12px)}

/* ── HERO STAT CARDS ── */
.stat-card{
  position:relative;
  padding:24px 20px;
  text-align:center;
  overflow:hidden;
  border-radius:12px;
  border:1px solid rgba(255,255,255,.05);
  background:rgba(17,24,39,.5);
  backdrop-filter:blur(20px);
  transition:all .6s var(--ease-out-expo);
}
.stat-card:hover{
  border-color:rgba(125,211,199,.12);
  transform:translateY(-4px);
  background:rgba(17,24,39,.7);
}
.stat-card::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;
  height:1px;
  background:linear-gradient(90deg,transparent,rgba(125,211,199,.15),transparent);
}

/* ── CONCEPT CARDS ── */
.concept-c{
  cursor:pointer;
  transition:all .5s var(--ease-out-expo);
  min-height:90px;
}
.concept-c:hover{
  border-color:rgba(125,211,199,.2)!important;
  box-shadow:0 8px 32px rgba(0,0,0,.3),0 0 20px rgba(125,211,199,.05);
  transform:translateY(-2px);
}
</style>
</head>
<body>

<!-- ██████████ PERMANENT DENIAL SCREEN ██████████ -->
<div id="denial-screen">
  <div style="position:absolute;inset:0;animation:redFlash 2.5s ease-in-out infinite"></div>
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(60,0,0,.4) 0%,#000 70%)"></div>
  <div style="position:relative;z-index:10;text-align:center;padding:0 24px;animation:fadeInUp .8s var(--ease-out-expo)">
    <div style="width:1px;height:80px;background:linear-gradient(180deg,transparent,rgba(239,68,68,.6),transparent);margin:0 auto 40px"></div>
    <div class="mono" style="color:rgba(239,68,68,.35);font-size:8px;letter-spacing:5px;margin-bottom:16px;text-transform:uppercase">WAVARA DEFENSE NETWORK — TERMINAL ACCESS</div>
    <div style="font-family:'Instrument Serif',serif;color:var(--red2);font-size:clamp(24px,5vw,42px);font-style:italic;margin-bottom:6px;letter-spacing:.5px">Access Permanently Denied</div>
    <div class="mono" style="color:rgba(239,68,68,.4);font-size:9px;letter-spacing:4px;text-transform:uppercase;margin-bottom:40px">SESSION TERMINATED</div>
    <div style="width:120px;height:1px;background:rgba(220,38,38,.2);margin:0 auto 40px"></div>
    <div class="mono" style="color:rgba(239,68,68,.28);font-size:8px;letter-spacing:2px;line-height:2.2">
      INCIDENT LOGGED — REF: <span id="denial-ref"></span><br/>
      SECURITY TEAM NOTIFIED<br/>
      IP ADDRESS FLAGGED<br/>
      FURTHER ATTEMPTS WILL BE PROSECUTED
    </div>
  </div>
</div>

<!-- ██████████ LOCKDOWN SCREEN ██████████ -->
<div id="lockdown-screen">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 38%,#140202 0%,#04080f 70%);z-index:0"></div>
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(220,38,38,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(220,38,38,.05) 1px,transparent 1px);background-size:56px 56px;z-index:1"></div>
  <div id="ld-scanline" style="position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(220,38,38,.35),transparent);z-index:2;animation:scanline 3s linear infinite"></div>
  <div class="glass" id="ld-panel" style="position:relative;z-index:10;max-width:460px;width:92%;border-color:rgba(220,38,38,.2);padding:0;overflow:hidden;animation:fadeInUp .8s var(--ease-out-expo)">
    <div style="background:rgba(220,38,38,.06);border-bottom:1px solid rgba(220,38,38,.15);padding:10px 28px;display:flex;justify-content:space-between;align-items:center">
      <span class="mono" style="font-size:7.5px;font-weight:700;letter-spacing:3px;color:rgba(239,68,68,.75);text-transform:uppercase;animation:blinkAlert 1.4s step-end infinite">⬛ SECURITY LOCKDOWN ACTIVE</span>
      <span class="mono" style="font-size:7.5px;color:rgba(239,68,68,.35);letter-spacing:2px">LD-7</span>
    </div>
    <div style="padding:44px 48px 48px">
      <div style="text-align:center;margin-bottom:36px">
        <div style="width:44px;height:44px;border:1px solid rgba(220,38,38,.3);border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;justify-content:center">
          <div style="width:18px;height:18px;border:1px solid rgba(220,38,38,.55);border-radius:50%;display:flex;align-items:center;justify-content:center"><div style="width:5px;height:5px;background:var(--red2);border-radius:50%"></div></div>
        </div>
        <div class="mono" style="font-size:7.5px;letter-spacing:3px;color:rgba(239,68,68,.45);text-transform:uppercase;margin-bottom:12px">Authentication Failure — Maximum Attempts Exceeded</div>
        <div style="font-family:'Instrument Serif',serif;font-size:26px;color:var(--red2);font-style:italic;margin-bottom:8px;letter-spacing:.3px">Level 5 Clearance Required</div>
        <div style="font-size:12px;color:rgba(239,68,68,.38);font-weight:300;line-height:1.6">Override access code required.<br/>One attempt permitted.</div>
      </div>
      <label class="mono" style="display:block;font-size:7.5px;letter-spacing:3px;color:rgba(239,68,68,.45);text-transform:uppercase;margin-bottom:10px">Level 5 Override Code</label>
      <input type="password" id="ld-input" placeholder="● ● ● ● ● ●" autocomplete="off" style="text-align:center;font-size:17px;border-color:rgba(220,38,38,.2)" onkeydown="if(event.key==='Enter')checkLvl5()"/>
      <div id="ld-error" style="min-height:18px;margin:10px 0;text-align:center;font-size:9px;color:var(--red2);letter-spacing:1px;opacity:0;transition:opacity .3s;font-weight:400"></div>
      <button onclick="checkLvl5()" style="width:100%;padding:15px;background:rgba(220,38,38,.08);border:1px solid rgba(239,68,68,.25);color:rgba(239,68,68,.8);border-radius:8px;font-size:10px;font-weight:500;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;margin-top:2px;transition:all .4s var(--ease-out-expo);font-family:'Inter',sans-serif" onmouseover="this.style.background='rgba(220,38,38,.14)'" onmouseout="this.style.background='rgba(220,38,38,.08)'">Verify Level 5 Override</button>
    </div>
  </div>
</div>

<!-- ██████████ LOCK SCREEN ██████████ -->
<div id="lock-screen">
  <!-- Atmospheric orbs -->
  <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none">
    <div style="position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(49,92,103,.18) 0%,transparent 70%);top:-200px;left:-200px;animation:orb 22s ease-in-out infinite"></div>
    <div style="position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,.08) 0%,transparent 70%);bottom:-150px;right:-100px;animation:orbSlow 28s ease-in-out infinite reverse"></div>
    <div style="position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(125,211,199,.06) 0%,transparent 70%);top:30%;right:15%;animation:orb 18s ease-in-out infinite 4s"></div>
  </div>
  <!-- Background grid -->
  <div id="ls-stars" style="position:absolute;inset:0;pointer-events:none;z-index:1"></div>
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%,rgba(12,30,54,.8) 0%,#040c16 65%,#020810 100%);z-index:0"></div>
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(36,52,71,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(36,52,71,.08) 1px,transparent 1px);background-size:64px 64px;z-index:0"></div>

  <!-- Subtle radar background -->
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-54%);pointer-events:none;z-index:1;opacity:.04">
    <svg width="700px" height="700px" viewBox="0 0 700 700">
      <circle cx="350" cy="350" r="320" fill="none" stroke="var(--seafoam)" stroke-width=".6"/>
      <circle cx="350" cy="350" r="220" fill="none" stroke="var(--seafoam)" stroke-width=".5"/>
      <circle cx="350" cy="350" r="120" fill="none" stroke="var(--seafoam)" stroke-width=".4"/>
      <line x1="30" y1="350" x2="670" y2="350" stroke="var(--seafoam)" stroke-width=".3"/>
      <line x1="350" y1="30" x2="350" y2="670" stroke="var(--seafoam)" stroke-width=".3"/>
      <line x1="350" y1="350" x2="350" y2="32" stroke="rgba(125,211,199,.85)" stroke-width="1" style="transform-origin:350px 350px;animation:radarSweep 9s linear infinite"/>
    </svg>
