  buoy:{label:'System B — Buoy Only',color:'var(--blue)',stats:{cost:5,speed:5,reliability:8,falseAlarm:3,evacuation:5},desc:'DART buoys confirm tsunami presence with high accuracy — but the wave must reach the buoy first, destroying the warning time advantage.'},
  hybrid:{label:'★ Hybrid WaveGuard',color:'var(--green)',stats:{cost:7,speed:8,reliability:10,falseAlarm:2,evacuation:9},desc:'Seismic speed + buoy confirmation accuracy. 6.5 hour warning advantage. Minimum false alarms. Superior across every metric.'}
};
var CMP_METRICS=[{key:'speed',label:'Detection Speed'},{key:'reliability',label:'Reliability'},{key:'evacuation',label:'Evacuation Advantage'},{key:'falseAlarm',label:'False Alarm Risk',invert:true},{key:'cost',label:'Implementation Cost',invert:true}];
