function setView(v) {
  currentView = v;
  ['surface', 'underground', 'satellite', 'cross', 'dashboard'].forEach(function(id) {
    var el = document.getElementById('view-' + id);
    if (el) el.style.display = (id === v) ? 'block' : 'none';
  });
  document.querySelectorAll('[id^="vbtn-"]').forEach(function(b) { b.classList.remove('active'); });
  var b = document.getElementById('vbtn-' + v);
  if (b) b.classList.add('active');
}

function startSim() {
  if (simState === 'running') return;
  resetSim();
  simState = 'running'; simStart = Date.now(); sDetected = bDetected = wIssued = false; seisPos = tsuPos = 0;
  document.getElementById('sim-btn').disabled = true;
  document.getElementById('sim-btn').textContent = '● RUNNING...';
  ['sv-pbar','ug-pbar','cs-pbar'].forEach(function(id){ var e=document.getElementById(id); if(e)e.style.display='block'; });
  document.getElementById('sv-complete').style.display='none';
  document.getElementById('emerg-panel').style.display='none';
  document.getElementById('sv-island-alert').style.display='none';
  document.getElementById('sv-arrows').style.display='none';
  var nd = document.getElementById('nav-sim-dot');
  if(nd){nd.style.background='var(--amber)';nd.style.boxShadow='0 0 6px var(--amber)';}
  addEqPulses();
  logEvent('T+0:00 — M' + P.magnitude + ' earthquake detected at epicentre.', 'var(--red2)');
  var DURATION = 9000;
  function animate() {
    var elapsed = Date.now() - simStart;
    var t = Math.min(elapsed / DURATION, 1);
    var seisT = Math.min(elapsed / (DURATION * 0.22), 1);
    var tsuT = Math.max(0, Math.min((elapsed - 700) / (DURATION * 0.86), 1));
    seisPos = seisT * 78; tsuPos = tsuT * 58;
    updateDot('sv-swave', seisPos); updateDot('ug-swave', seisPos, true); updateDot('cs-swave', seisPos, false, true);
    updateTsuPos(tsuPos);
    updateSeisRings(seisPos);
    var str = document.getElementById('sat-tsunami-ring');
    if (str) str.setAttribute('r', String(tsuPos * 3.8));
    var pfPct = t * 100;
    ['sv-pfill','ug-pfill','cs-pfill'].forEach(function(id){ var e=document.getElementById(id); if(e)e.style.width=pfPct+'%'; });
    var tlf = document.getElementById('tl-tsunami-fill');
    if (tlf) tlf.style.width = (tsuT * 100) + '%';
    if (t > 0.2 && !sDetected) { sDetected=true; onSeisDetected(); }
    if (t > 0.48 && !bDetected) { bDetected=true; onBuoyDetected(); }
    if (t > 0.54 && !wIssued) { wIssued=true; onWarning(); }
    updateLiveData();
    if (t < 1) simRAF = requestAnimationFrame(animate); else onSimComplete();
  }
  simRAF = requestAnimationFrame(animate);
}

function updateDot(id, pos, ugMode, csMode) {
  var el = document.getElementById(id);
  if (!el) return;
  el.style.left = (15 + pos * 0.58) + '%';
  el.style.display = pos > 0 ? 'block' : 'none';
  if (ugMode) { el.style.bottom = '94px'; } else if (csMode) { el.style.bottom = '86px'; }
}

function updateTsuPos(pos) {
  var pct = 15 + pos * 0.52;
  ['sv-tsunami','cs-tsunami'].forEach(function(id){ var el=document.getElementById(id); if(el){el.style.left=pct+'%';el.style.display=pos>0?'block':'none';} });
  if (pos > 0) { var a=document.getElementById('sv-arrows'); if(a)a.style.display='block'; }
}

function updateSeisRings(pos) {
  var r = pos * 1.4;
  ['ugr1','ugr2','ugr3'].forEach(function(id,i){ var el=document.getElementById(id); if(el)el.setAttribute('r',String(Math.max(0,r-i*11))); });
