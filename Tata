  var spd=Math.round(f*wl);
  setText('eq-fv',f.toFixed(1)+' Hz'); setText('eq-wv',wl+' m');
  setText('eq-f-disp',f.toFixed(1)+' Hz'); setText('eq-w-disp',wl+' m'); setText('eq-spd-disp',spd+' m/s');
  setText('eq-wl-ann','λ = '+wl+'m');
  setText('eq-formula','v = f × λ = '+f+' × '+wl+' = '+spd+' m/s  ·  T = 1/f = '+(1/f).toFixed(3)+' s');
}
function startEqAnim() {
  if(eqRAF)return;
  var t=0;
  function frame() {
    t+=0.05;
    var f=parseFloat(document.getElementById('eq-f').value)||2;
    var wl=parseFloat(document.getElementById('eq-w').value)||80;
    var W=560,H=115;
    var k=(2*Math.PI)/wl;
    var omega=2*Math.PI*f;
    var pts=[];
    for(var x=0;x<=W;x+=2){var y=H/2+34*Math.sin(k*x-omega*t*0.02);pts.push(x+','+y);}
    var ep=document.getElementById('eq-path'); if(ep)ep.setAttribute('d','M '+pts.join(' L '));
    var wll=document.getElementById('eq-wl-line'); if(wll)wll.setAttribute('x2',20+wl);
    var wla=document.getElementById('eq-wl-ann'); if(wla)wla.setAttribute('x',20+wl/2);
    eqRAF=requestAnimationFrame(frame);
  }
  frame();
}
function stopEqAnim(){if(eqRAF){cancelAnimationFrame(eqRAF);eqRAF=null;}}

