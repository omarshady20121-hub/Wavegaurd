/* ════════ CALCULATIONS ════════ */
function seisTime() { return (P.distance / P.seismicSpeed) * 60; }
function tsuTime() { return P.distance / P.tsunamiSpeed; }
function hybridAdv() { return Math.max(0, tsuTime() - seisTime() / 60); }
function reliab() { return Math.min(99.9, 70 + P.buoySensitivity * 0.25 + (P.magnitude > 6 ? 8 : 0)); }
function threatPct() { return Math.min(100, Math.max(0, ((P.magnitude - 5) / 4) * 100)); }
function setText(id, t) { var e = document.getElementById(id); if (e) e.textContent = t; }

function updateParams() {
  P.magnitude      = parseFloat(document.getElementById('sl-mag').value);
  P.distance       = parseFloat(document.getElementById('sl-dist').value);
  P.seismicSpeed   = parseFloat(document.getElementById('sl-sspd').value);
  P.tsunamiSpeed   = parseFloat(document.getElementById('sl-tspd').value);
  P.oceanDepth     = parseFloat(document.getElementById('sl-depth').value);
  P.buoySensitivity = parseFloat(document.getElementById('sl-bsens').value);
  setText('v-mag', P.magnitude.toFixed(1) + ' M');
  setText('v-dist', P.distance + ' km');
  setText('v-sspd', P.seismicSpeed + ' km/h');
  setText('v-tspd', P.tsunamiSpeed + ' km/h');
  setText('v-depth', P.oceanDepth + ' m');
  setText('v-bsens', P.buoySensitivity + '%');
  var sm = seisTime().toFixed(1);
  setText('f-eq-val', 't = ' + P.distance + '/' + P.seismicSpeed + ' = ' + sm + ' min');
