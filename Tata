function pentagon(cx,cy,r){return Array.from({length:5},function(_,i){var a=(i/5)*Math.PI*2-Math.PI/2;return (cx+r*Math.cos(a))+','+(cy+r*Math.sin(a));}).join(' ');}
function radarPts(cx,cy,vals,maxR){var n=vals.length;return vals.map(function(v,i){var a=(i/n)*Math.PI*2-Math.PI/2;var r=(v/10)*maxR;return (cx+r*Math.cos(a))+','+(cy+r*Math.sin(a));}).join(' ');}

function initRadar(){[2,4,6,8,10].forEach(function(lvl){var el=document.getElementById('rp'+lvl);if(el)el.setAttribute('points',pentagon(150,118,lvl/10*86));});}
function updateRadar(){
  Object.entries(CMP).forEach(function(e){var key=e[0],sys=e[1];var el=document.getElementById('radar-'+key);if(!el)return;var vals=[sys.stats.speed,sys.stats.reliability,sys.stats.evacuation,10-sys.stats.falseAlarm,10-sys.stats.cost];el.setAttribute('points',radarPts(150,118,vals,86));var isSel=key===selectedSys;el.setAttribute('stroke-width',isSel?'2.2':'1');el.setAttribute('stroke-opacity',isSel?'1':'.4');});
}

/* ════════ GRAPHS ════════ */
function updateGraphs(){
  var depths=[500,1000,2000,3000,4000,5000,6000,7000,8000,10000,12000];
  var speeds=depths.map(function(d){return Math.round(Math.sqrt(9.81*d)*3.6);});
  var maxSpd=Math.max.apply(null,speeds);
  var W=260,H=162,pL=35,pB=27,pT=11,pR=8;
  var gW=W-pL-pR,gH=H-pB-pT;
  var dToX=function(d){return pL+((d-500)/(12000-500))*gW;};
  var sToY=function(s){return pT+gH-(s/maxSpd)*gH;};
  var lp=depths.map(function(d,i){return (i===0?'M':'L')+' '+dToX(d)+' '+sToY(speeds[i]);}).join(' ');
  var pathEl=document.getElementById('g-depth-path'); if(pathEl)pathEl.setAttribute('d',lp);
  var curX=dToX(Math.min(P.oceanDepth,12000));
  var curSpd=Math.round(Math.sqrt(9.81*P.oceanDepth)*3.6);
  var curY=sToY(Math.min(curSpd,maxSpd));
  var vl=document.getElementById('g-depth-vline'); if(vl){vl.setAttribute('x1',curX);vl.setAttribute('x2',curX);}
  var dot=document.getElementById('g-depth-dot'); if(dot){dot.setAttribute('cx',curX);dot.setAttribute('cy',curY);}
  setText('g-depth-lbl',P.oceanDepth+'m → '+curSpd+' km/h');
  var g=document.getElementById('g-speed-bars');
  if(g){
    var items=[{lbl:'Seismic Wave',val:P.seismicSpeed,color:'var(--amber)'},{lbl:'Tsunami Wave',val:P.tsunamiSpeed,color:'var(--blue)'},{lbl:'Sound (Water)',val:5400,color:'rgba(155,179,200,.5)'}];
    var maxV=Math.max.apply(null,[P.seismicSpeed,P.tsunamiSpeed,5400,1]);
    g.innerHTML=items.map(function(it,i){var bw=Math.max(4,(it.val/maxV)*215);var y=18+i*44;var vs=it.val>=1000?(it.val/1000).toFixed(1)+'k':it.val;return '<text x="9" y="'+y+'" fill="'+it.color+'" font-size="8.5" font-family="\'Courier New\',monospace">'+it.lbl+'</text><rect x="9" y="'+(y+5)+'" width="'+bw+'" height="15" rx="2" fill="'+it.color+'" fill-opacity=".15"/><rect x="9" y="'+(y+5)+'" width="'+bw+'" height="2" rx="1" fill="'+it.color+'"/><text x="'+(13+bw)+'" y="'+(y+17)+'" fill="'+it.color+'" font-size="7.5" font-family="\'Courier New\',monospace">'+vs+' km/h</text>';}).join('');
    var ratio=Math.round(P.seismicSpeed/P.tsunamiSpeed);
    setText('g-speed-note','Seismic ~'+ratio+'× faster than tsunami');
  }
}

/* ════════ INIT ════════ */
function initApp(){
  genStars('hero-stars',45);
  updateParams(); updateLiveData(); initRadar(); selectSys('seismic'); updateGraphs();
  document.getElementById('safety-date').textContent=new Date().toUTCString();
}
</script>
