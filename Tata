  '> [  OK  ] Hybrid AI fusion engine — calibrated',
  '> [  OK  ] Warning broadcast system — armed',
  '> SYSTEM READY — ALL SENSORS NOMINAL',
];
var bootIndex = 0;
function startLoad() {
  var prog = 0;
  var bar = document.getElementById('load-bar');
  var ph = document.getElementById('load-phase');
  var pct = document.getElementById('load-pct');
  var log = document.getElementById('boot-log');
  var phases = ['Initialising network...','Loading sensor array...','Calibrating DART buoys...','Connecting satellite...','Synchronising telemetry...','System ready'];
  bootIndex = 0;
  if (log) log.innerHTML = '';
  var iv = setInterval(function() {
    prog += Math.random() * 3.2 + 0.8;
    if (prog >= 100) {
      prog = 100;
      clearInterval(iv);
      if (bar) bar.style.width = '100%';
      if (ph) ph.textContent = phases[5];
      if (pct) pct.textContent = '100%';
      setTimeout(function() {
        document.getElementById('loading-screen').style.display = 'none';
        document.getElementById('app').style.display = 'block';
        initApp();
      }, 500);
    } else {
      if (bar) bar.style.width = prog + '%';
      var pi = Math.min(Math.floor((prog / 100) * phases.length), phases.length - 2);
      if (ph) ph.textContent = phases[pi];
      if (pct) pct.textContent = Math.round(prog) + '%';
      var li = Math.floor((prog / 100) * bootLines.length);
      if (log && li > bootIndex && bootIndex < bootLines.length) {
        var d = document.createElement('div');
        d.style.animation = 'bootText .25s var(--ease-out-expo)';
        d.textContent = bootLines[bootIndex];
        log.appendChild(d);
        log.scrollTop = log.scrollHeight;
        bootIndex++;
      }
    }
  }, 55);
}

