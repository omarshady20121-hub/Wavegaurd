<script>
/* ════════ PASSWORDS ════════ */
var MAIN_PW = 'WAVARA';
var LVL5_PW = 'SENTINEL';
var OMK_PW = 'HYBRID';
var FAIL_KEY = 'wg_fails';
var LOCK_KEY = 'wg_locked';
var DENY_KEY = 'wg_denied';
var MAX_FAILS = 3;

/* ════════ INIT CHECK ════════ */
(function() {
  if (localStorage.getItem(DENY_KEY) === '1') {
    showDenied(); return;
  }
  if (localStorage.getItem(LOCK_KEY) === '1') {
    showLockdown(); return;
  }
  var fails = parseInt(localStorage.getItem(FAIL_KEY) || '0');
  buildAttemptRow(fails);
})();

function buildAttemptRow(fails) {
  var row = document.getElementById('attempt-row');
  if (!row) return;
  row.innerHTML = '';
  for (var i = 0; i < MAX_FAILS; i++) {
    var d = document.createElement('div');
    d.style.cssText = 'width:7px;height:7px;border-radius:50%;transition:all .4s var(--ease-out-expo);border:1px solid ' + (i < fails ? 'rgba(239,68,68,.5)' : 'rgba(36,52,71,.8)') + ';background:' + (i < fails ? 'var(--red2)' : 'transparent');
    row.appendChild(d);
  }
}

function checkLock() {
  var v = (document.getElementById('lock-input').value || '').trim().toUpperCase();
  var fails = parseInt(localStorage.getItem(FAIL_KEY) || '0');
  if (v === MAIN_PW) {
    localStorage.removeItem(FAIL_KEY);
    var ls = document.getElementById('lock-screen');
    ls.style.animation = 'lockReveal .6s var(--ease-out-expo) forwards';
    setTimeout(function() {
      ls.style.display = 'none';
      var loading = document.getElementById('loading-screen');
      loading.style.display = 'flex';
      loading.style.flexDirection = 'column';
      loading.style.alignItems = 'center';
      loading.style.justifyContent = 'center';
      startLoad();
    }, 620);
  } else {
    fails++;
    localStorage.setItem(FAIL_KEY, fails);
    buildAttemptRow(fails);
    var e = document.getElementById('lock-error');
    e.textContent = fails >= MAX_FAILS ? 'Maximum attempts exceeded — initiating lockdown' : 'Incorrect access code — ' + (MAX_FAILS - fails) + ' attempt' + (MAX_FAILS - fails === 1 ? '' : 's') + ' remaining';
    e.style.opacity = '1';
    var p = document.getElementById('lock-panel');
    p.style.animation = 'shake .5s ease';
    setTimeout(function() { p.style.animation = ''; }, 520);
    if (fails >= MAX_FAILS) {
      localStorage.setItem(LOCK_KEY, '1');
      setTimeout(function() { showLockdown(); }, 1400);
    } else {
      setTimeout(function() { e.style.opacity = '0'; }, 3500);
    }
    document.getElementById('lock-input').value = '';
    document.getElementById('lock-input').focus();
  }
}
document.getElementById('lock-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') checkLock(); });

function showLockdown() {
  document.getElementById('lock-screen').style.display = 'none';
  document.getElementById('loading-screen').style.display = 'none';
  var ld = document.getElementById('lockdown-screen');
  ld.style.display = 'flex';
  ld.style.flexDirection = 'column';
  ld.style.alignItems = 'center';
  ld.style.justifyContent = 'center';
  document.getElementById('ld-input').value = '';
}

function checkLvl5() {
  var v = (document.getElementById('ld-input').value || '').trim().toUpperCase();
  if (v === LVL5_PW) {
    localStorage.removeItem(FAIL_KEY);
    localStorage.removeItem(LOCK_KEY);
    localStorage.removeItem(DENY_KEY);
    document.getElementById('lockdown-screen').style.display = 'none';
    var ls = document.getElementById('loading-screen');
    ls.style.display = 'flex';
    ls.style.flexDirection = 'column';
    ls.style.alignItems = 'center';
    ls.style.justifyContent = 'center';
    startLoad();
  } else {
    localStorage.setItem(DENY_KEY, '1');
    var e = document.getElementById('ld-error');
    e.textContent = 'Invalid Level 5 code — access permanently revoked';
    e.style.opacity = '1';
    var p = document.getElementById('ld-panel');
    p.style.animation = 'shake .5s ease';
    setTimeout(function() { p.style.animation = ''; }, 520);
    setTimeout(function() {
      document.getElementById('lockdown-screen').style.display = 'none';
      showDenied();
    }, 1200);
  }
}
document.getElementById('ld-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') checkLvl5(); });

function showDenied() {
  document.getElementById('lock-screen').style.display = 'none';
  document.getElementById('loading-screen').style.display = 'none';
  document.getElementById('lockdown-screen').style.display = 'none';
